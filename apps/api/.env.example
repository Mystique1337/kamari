# Kamari API gateway env. Copy to .env and fill in. NEVER commit the real .env.
# On Railway, set these as service variables instead.

# --- Modal model endpoints (always-on; min_containers=1) ---
MODAL_AGE_ENDPOINT=https://<ns>--kamari-cnn-serve-endpoint.modal.run
MODAL_GEMMA_ENDPOINT=https://<ns>--kamari-gemma-serve-endpoint.modal.run

# --- Supabase (self-hosted) ---
SUPABASE_URL=https://your-supabase-host
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# JWT secret used to VERIFY GoTrue access tokens (project JWT secret).
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUD=authenticated
# Schema holding kamari tables. Use "public" (see infra/postgres/schema_public.sql)
# or "kamari" if you expose it to PostgREST (PGRST_DB_SCHEMAS).
SUPABASE_DB_SCHEMA=public

# --- Security ---
# Hash pepper for API keys. Change in production.
API_KEY_PEPPER=change-me
# Require a valid API key on /v1/age/* (stamps org-scoped usage). False for open demo.
REQUIRE_API_KEY=false

# --- n8n email (Dynamic Email Template Sender workflow) ---
N8N_EMAIL_WEBHOOK_URL=https://your-n8n-host/webhook/email_send
N8N_EMAIL_HEADER_NAME=EMAIL_SECRET
N8N_EMAIL_HEADER_SECRET=
EMAIL_FROM_NAME=Kamari

# --- App ---
# Public URL of the deployed web app (Railway). Used in email links.
APP_PUBLIC_URL=https://your-app.up.railway.app

# Privacy default. The gateway never stores raw images.
RETENTION_DEFAULT=image_not_stored
