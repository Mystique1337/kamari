# Kámárí app env — copy to .env.local for local dev (Vite auto-loads it).

# The ONLY thing the app waits on from the ML side: the gateway base URL.
# Point this at the Railway FastAPI gateway (which calls the Modal CNN/Gemma endpoints).
# Leave empty to use the built-in mock so the full flow is demoable offline.
VITE_KAMARI_API_URL=

# Force the mock even when a URL is set (1 = mock, 0/unset = live when URL present).
VITE_USE_MOCK=1

# Supabase (auth, later milestones)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
