# Kámárí environment — copy to .env and fill in. NEVER commit the real .env.

# --- Hugging Face (datasets, models, cards) ---
# Token with WRITE access. Create at https://huggingface.co/settings/tokens
HF_TOKEN=
# Your HF user or org namespace, e.g. "kamari" or "chidiashinze".
# All Kámárí repos are created under this: <HF_NAMESPACE>/cnn-age-v0, etc.
HF_NAMESPACE=kamari

# --- Kaggle (some datasets download via the Kaggle API) ---
# From https://www.kaggle.com/settings -> "Create New Token" (kaggle.json).
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Optional dataset sources for notebooks/kamari_data_pipeline_v2.ipynb ---
# Use these only after confirming licence/consent/access terms.
PUBLISH_TO_HF=0
KAMARI_DOWNLOAD_LARGE=1
ALLOW_PRIVATE_CROP_UPLOAD=0
# Direct-download defaults where a public archive/folder exists.
FAIRFACE_URL=https://drive.google.com/uc?export=download&id=1Z1RqRo0_JiavaZw2yzZG6WETdZQ8qX86
APPA_REAL_URL=https://data.chalearnlap.cvc.uab.cat/AppaRealAge/appa-real-release.zip
# Adience source/request page: https://www.cslab.openu.ac.il/download/
ADIENCE_URL=
# AgeDB source/request page: https://ibug.doc.ic.ac.uk/resources/agedb/
AGEDB_URL=
AGEDB_HF_REPO=
FGNET_URL=http://yanweifu.github.io/FG_NET_data/FGNET.zip
AAF_URL=https://www.dropbox.com/s/a0lj1ddd54ns8qy/All-Age-Faces%20Dataset.zip?dl=1
AAF_HF_REPO=
# FAGE_v2 source paper: https://arxiv.org/abs/2408.06806
FAGE_HF_REPO=
# AxonData source is usually HF/private; verify exact terms before use.
AXONDATA_URL=
AXONDATA_HF_REPO=
LFW_URL=http://vis-www.cs.umass.edu/lfw/lfw.tgz
# RFW source/request page: http://www.whdeng.cn/RFW/index.html
RFW_URL=
RFW_HF_REPO=
BFW_URL=https://www.dropbox.com/scl/fo/i2gj82qewyikts2d55xo5/AK5cY0nmJ7Of-iHmD6eF9E4?rlkey=ebj8bbq0giwk30v75r51vsw75&st=slcmpmbn&dl=1
BFW_HF_REPO=
CELEBA_SPOOF_URL=https://drive.google.com/drive/folders/1OW_1bawO79pRqdVEVmBzp8HSxdSwln_Z?usp=sharing
CELEBA_SPOOF_HF_REPO=
# CeFA source/request page: https://sites.google.com/qq.com/face-anti-spoofing/dataset-download/casia-surf-cefa
CEFA_URL=
# OULU-NPU source/request page: https://sites.google.com/site/oulunpudatabase/
OULU_NPU_URL=
# CASIA dataset portal: http://www.cripacsir.cn/dataset/
CASIA_FACE_AFRICA_URL=
BVC_UNN_URL=
NEFI_URL=

# --- Modal (training + serving). Authorize with: modal setup ---
# These are set as Modal Secrets, not read locally, but listed here for reference:
#   modal secret create kamari-hf HF_TOKEN=... HF_NAMESPACE=...
#   modal secret create kamari-wandb WANDB_API_KEY=...   (optional)

# --- Optional: Weights & Biases experiment tracking ---
# If empty, training falls back to local JSON metrics + HF artifacts only.
WANDB_API_KEY=
WANDB_PROJECT=kamari

# --- Pipeline paths (override if needed) ---
KAMARI_DATA_ROOT=./data
