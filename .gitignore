# --- Claude Code (internal authoring config; kept local, not part of the public deliverable) ---
.claude/

# --- Node / frontend (apps/kamari_app) ---
node_modules/
dist/
.vite/
*.local
.eslintcache

# Capacitor: the Android project is committed so CI can build the APK with our
# manifest (camera permission). Its own android/.gitignore excludes build output.
# iOS is regenerated on demand via `npx cap add ios`.
apps/kamari_app/ios/

# --- Python / API & ML (apps/api, training, services) ---
__pycache__/
*.py[cod]
.venv/
venv/
.env
.env.*
!.env.example
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# --- ML artifacts & data (do NOT commit raw faces or large binaries) ---
data/raw/
data/interim/
data/processed/crops_*/
outputs/
*.pt
*.ckpt
*.onnx
*.tflite
*.parquet
weights/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
