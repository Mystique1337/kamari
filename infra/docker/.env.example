# Optional env for the Kamari self-host stack. Copy to .env. Everything here is optional:
# the stack runs a working age gate (web + gateway + CPU CNN) with none of it set.

# --- Models ---
# Leave Gemma empty to use approved template messages (no GPU). Point it at a Gemma endpoint
# (e.g. your Modal deploy) to get model-written, multilingual explanations.
MODAL_GEMMA_ENDPOINT=
# Only needed if you make cnn-age-v0 private; it is public by default.
HF_TOKEN=

# --- Developer portal + logging (Supabase). Optional; age checks work without it. ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Security ---
API_KEY_PEPPER=change-me
REQUIRE_API_KEY=false

# --- Email (n8n). Optional. ---
N8N_EMAIL_WEBHOOK_URL=
N8N_EMAIL_HEADER_NAME=EMAIL_SECRET
N8N_EMAIL_HEADER_SECRET=

# --- URLs ---
APP_PUBLIC_URL=http://localhost:8080
# If you serve the gateway on another host/port, set this so the web build calls the right URL.
VITE_KAMARI_API_URL=http://localhost:8000
